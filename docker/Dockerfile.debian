FROM rust:bookworm AS builder
WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY src ./src
RUN cargo build --release --locked

# Build the DNS filter shared library
RUN gcc -shared -fPIC -o /app/target/release/librune_dns_filter.so \
    /app/src/dns_filter.c -ldl

FROM debian:bookworm-slim
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# Install all rune binaries
COPY --from=builder /app/target/release/rune /usr/local/bin/rune
COPY --from=builder /app/target/release/rune-seccomp /usr/local/bin/rune-seccomp
COPY --from=builder /app/target/release/rune-landlock /usr/local/bin/rune-landlock
COPY --from=builder /app/target/release/librune_dns_filter.so /usr/local/lib/librune_dns_filter.so
RUN chmod 0755 /usr/local/bin/rune /usr/local/bin/rune-seccomp /usr/local/bin/rune-landlock \
    && chmod 0644 /usr/local/lib/librune_dns_filter.so

# Concourse resource type: /opt/resource/{check,in,out}
RUN mkdir -p /opt/resource \
    && ln -sf /usr/local/bin/rune /opt/resource/check \
    && ln -sf /usr/local/bin/rune /opt/resource/in \
    && ln -sf /usr/local/bin/rune /opt/resource/out

# Note: Concourse resource containers must run as root
# (worker mounts volumes as root). Non-root user is available
# for task steps that use this image directly.
RUN useradd --uid 1000 --create-home --home-dir /home/rune --shell /usr/sbin/nologin rune

ENTRYPOINT ["/usr/local/bin/rune"]
